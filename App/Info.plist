<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>Container Monitor</string>
    <key>CFBundleDisplayName</key>
    <string>Container Monitor</string>
    <key>CFBundleIdentifier</key>
    <string>com.containermonitor.app</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleExecutable</key>
    <string>ContainerDashboard</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <!-- README documents macOS 26+ as the floor for Apple's `container` CLI;
         this is the true required floor, not the SwiftPM target (14.0). Older
         systems get a clean LaunchServices refusal instead of a runtime crash. -->
    <key>LSMinimumSystemVersion</key>
    <string>26.0</string>
    <key>NSHighResolutionCapable</key>
    <true/>
    <!-- The dashboard is served over plain loopback HTTP. NSAllowsLocalNetworking
         permits loopback/localhost cleartext without disabling ATS globally. -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsLocalNetworking</key>
        <true/>
    </dict>
</dict>
</plist>
